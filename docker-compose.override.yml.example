# Local docker-compose overrides with development secrets.
# DO NOT COMMIT this file — it's git-ignored and contains credentials.
#
# Usage:
#   1. Copy this file to docker-compose.override.yml
#   2. Fill in your actual DB credentials
#   3. Run: docker-compose up -d
#
# Note: docker-compose automatically merges docker-compose.override.yml with docker-compose.yml.

services:
  postgres:
    environment:
      # Change these for local development if the defaults in docker-compose.yml
      # do not match your machine.
      POSTGRES_DB: skyn
      POSTGRES_USER: skynapi
      POSTGRES_PASSWORD: YOUR_PASSWORD
    ports:
      # Change the host port if 5432 is already in use.
      - "5432:5432"

  skynapi:
    environment:
      # Set your local database credentials here.
      DB_URL: host=postgres dbname=skyn user=skynapi password=YOUR_PASSWORD sslmode=disable
